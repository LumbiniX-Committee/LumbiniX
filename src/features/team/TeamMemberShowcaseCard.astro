---
import type { TeamMemberProfile } from "../../types";

interface Props {
  member: TeamMemberProfile;
  featured?: boolean;
}

const { member, featured = false } = Astro.props;

const frame = featured
  ? "glass-card p-8 md:p-10 border-2 border-primary/15 dark:border-primary/25 shadow-lg shadow-primary/5 dark:shadow-primary/15 hover:border-primary/35 hover:shadow-primary/10 dark:hover:shadow-primary/25"
  : "glass-card p-6 md:p-8 border border-slate-200/80 dark:border-dark-border hover:border-primary/25 dark:hover:border-primary/40 hover:shadow-md dark:hover:shadow-primary/10";

const imgClass = featured
  ? "w-36 h-36 md:w-44 md:h-44 mx-auto mb-6 rounded-full object-cover border-4 border-white dark:border-dark-card shadow-xl ring-2 ring-primary/15 dark:ring-primary/30 group-hover:ring-primary/40 group-hover:border-primary/30 dark:group-hover:border-primary/50 transition-all duration-300 group-hover:scale-105"
  : "w-28 h-28 md:w-32 md:h-32 mx-auto mb-5 rounded-full object-cover border-4 border-white dark:border-dark-card shadow-lg ring-2 ring-slate-100 dark:ring-dark-border group-hover:ring-primary/30 group-hover:border-primary/20 dark:group-hover:border-primary/40 transition-all duration-300 group-hover:scale-105";
---

<article
  class:list={[frame, "group text-center flex flex-col items-center transition-all duration-300 hover:-translate-y-1 hover:scale-[1.02]"]}
>
  <div class:list={[featured ? "relative mb-2" : "relative mb-1"]}>
    <div
      class="absolute inset-0 bg-primary/10 dark:bg-primary/20 rounded-full blur-2xl opacity-0 group-hover:opacity-100 transition-opacity duration-500 scale-110"
      aria-hidden="true"
    >
    </div>
    <img
      src={member.image}
      alt={member.name}
      width={featured ? 176 : 128}
      height={featured ? 176 : 128}
      class:list={["relative", imgClass]}
      loading="lazy"
    />
  </div>

  <h3
    class:list={[featured ? "text-2xl md:text-3xl" : "text-lg md:text-xl", "font-display font-bold text-slate-900 dark:text-white tracking-tight"]}
  >
    {member.name}
  </h3>
  <p
    class:list={[featured ? "text-base md:text-lg mt-2" : "text-sm md:text-base mt-1.5", "font-bold text-primary dark:text-primary-light"]}
  >
    {member.role}
  </p>

  <div class:list={[featured ? "mt-8 gap-4" : "mt-6 gap-3", "flex items-center justify-center opacity-70 group-hover:opacity-100 transition-opacity"]}>
    {member.instagramUrl && (
      <a
        href={member.instagramUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex h-10 w-10 items-center justify-center rounded-full border border-slate-200 dark:border-dark-border bg-white dark:bg-dark-surface text-slate-500 dark:text-slate-400 shadow-sm hover:text-pink-500 hover:border-pink-400/40 hover:bg-pink-50 dark:hover:bg-pink-500/10 transition-all duration-300 hover:scale-110"
        aria-label={`${member.name} on Instagram`}
      >
        <svg class="h-[18px] w-[18px]" viewBox="0 0 24 24" aria-hidden="true" fill="currentColor">
          <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
        </svg>
      </a>
    )}
    {member.facebookUrl && (
      <a
        href={member.facebookUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex h-10 w-10 items-center justify-center rounded-full border border-slate-200 dark:border-dark-border bg-white dark:bg-dark-surface text-slate-500 dark:text-slate-400 shadow-sm hover:text-blue-600 hover:border-blue-400/40 hover:bg-blue-50 dark:hover:bg-blue-500/10 transition-all duration-300 hover:scale-110"
        aria-label={`${member.name} on Facebook`}
      >
        <svg class="h-[18px] w-[18px]" viewBox="0 0 24 24" aria-hidden="true" fill="currentColor">
          <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
        </svg>
      </a>
    )}
    {member.linkedinUrl && (
      <a
        href={member.linkedinUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex h-10 w-10 items-center justify-center rounded-full border border-slate-200 dark:border-dark-border bg-white dark:bg-dark-surface text-slate-500 dark:text-slate-400 shadow-sm hover:text-primary hover:border-primary/40 hover:bg-primary/5 dark:hover:bg-primary/10 transition-all duration-300 hover:scale-110"
        aria-label={`${member.name} on LinkedIn`}
      >
        <svg class="h-[18px] w-[18px]" viewBox="0 0 24 24" aria-hidden="true" fill="currentColor">
          <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
        </svg>
      </a>
    )}
  </div>
</article>
