---
import type { TeamMemberProfile } from "../../types";

interface Props {
  member: TeamMemberProfile;
  featured?: boolean;
}

const { member, featured = false } = Astro.props;

const frame = featured
  ? "glass-card p-8 md:p-10 border-2 border-primary/15 shadow-lg shadow-primary/5 hover:border-primary/35 hover:shadow-primary/10"
  : "glass-card p-6 md:p-8 border border-slate-200/80 hover:border-primary/25 hover:shadow-md";

const imgClass = featured
  ? "w-36 h-36 md:w-44 md:h-44 mx-auto mb-6 rounded-full object-cover border-4 border-white shadow-xl ring-2 ring-primary/15 group-hover:ring-primary/40 group-hover:border-primary/30 transition-all duration-300"
  : "w-28 h-28 md:w-32 md:h-32 mx-auto mb-5 rounded-full object-cover border-4 border-white shadow-lg ring-2 ring-slate-100 group-hover:ring-primary/30 group-hover:border-primary/20 transition-all duration-300";
---

<article
  data-stagger-item
  class:list={[frame, "group text-center flex flex-col items-center transition-all duration-300 hover:-translate-y-1"]}
>
  <div class:list={[featured ? "relative mb-2" : "relative mb-1"]}>
    <div
      class="absolute inset-0 bg-primary/10 rounded-full blur-2xl opacity-0 group-hover:opacity-100 transition-opacity duration-500 scale-110"
      aria-hidden="true"
    >
    </div>
    <img
      src={member.image}
      alt={member.name}
      width={featured ? 176 : 128}
      height={featured ? 176 : 128}
      class:list={["relative", imgClass]}
      loading="lazy"
    />
  </div>

  <h3
    class:list={[featured ? "text-2xl md:text-3xl" : "text-lg md:text-xl", "font-display font-bold text-slate-900 tracking-tight"]}
  >
    {member.name}
  </h3>
  <p
    class:list={[featured ? "text-base md:text-lg mt-2" : "text-sm md:text-base mt-1.5", "font-bold text-primary"]}
  >
    {member.role}
  </p>

  <div class:list={[featured ? "mt-8 gap-4" : "mt-6 gap-3", "flex items-center justify-center"]}>
    <a
      href={member.twitterUrl}
      target="_blank"
      rel="noopener noreferrer"
      class="inline-flex h-10 w-10 items-center justify-center rounded-full border border-slate-200 bg-white text-slate-500 shadow-sm hover:text-primary hover:border-primary/40 hover:bg-primary/5 transition-colors"
      aria-label={`${member.name} on X`}
    >
      <svg class="h-[18px] w-[18px]" viewBox="0 0 24 24" aria-hidden="true" fill="currentColor">
        <path
          d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"
        ></path>
      </svg>
    </a>
    <a
      href={member.linkedinUrl}
      target="_blank"
      rel="noopener noreferrer"
      class="inline-flex h-10 w-10 items-center justify-center rounded-full border border-slate-200 bg-white text-slate-500 shadow-sm hover:text-primary hover:border-primary/40 hover:bg-primary/5 transition-colors"
      aria-label={`${member.name} on LinkedIn`}
    >
      <svg class="h-[18px] w-[18px]" viewBox="0 0 24 24" aria-hidden="true" fill="currentColor">
        <path
          d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"
        ></path>
      </svg>
    </a>
  </div>
</article>
