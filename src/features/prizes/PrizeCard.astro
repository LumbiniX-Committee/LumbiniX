---
import type { Prize } from "../../types";
import { Trophy } from "lucide-react";

interface Props {
  prize: Prize;
  index: number;
}

const { prize, index } = Astro.props;

const isFirst = index === 0;
---

<div class={`glass-card p-8 relative overflow-hidden group shadow-xl ${isFirst ? 'border-primary/40 ring-4 ring-primary/5 scale-105 z-10 bg-white' : 'bg-white/80'}`}>
  {isFirst && (
    <div class="absolute top-0 right-0 p-4">
      <Trophy class="text-accent-dark animate-bounce" size={32} />
    </div>
  )}
  
  <div class="mb-6">
    <span class="text-sm font-bold uppercase tracking-widest text-primary mb-2 block">{prize.tier}</span>
    <h3 class="text-4xl font-display font-bold text-slate-900 mb-4">{prize.amount}</h3>
    <p class="text-slate-600 leading-relaxed text-sm">{prize.description}</p>
  </div>

  <div class="aspect-video rounded-xl overflow-hidden mb-6 shadow-inner bg-slate-100">
    <img 
      src={prize.image} 
      alt={prize.tier}
      class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
    />
  </div>

  <ul class="space-y-3">
    {["Cash Prize", "Sponsor Swag", "Mentorship Access"].map((item) => (
      <li class="flex items-center gap-3 text-sm text-slate-700 font-medium">
        <div class="w-2 h-2 rounded-full bg-accent shadow-sm"></div>
        {item}
      </li>
    ))}
  </ul>
</div>
