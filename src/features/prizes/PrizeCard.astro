---
import type { Prize } from "../../types";
import { Gift } from "lucide-react";

interface Props {
  prize: Prize;
  index: number;
}

const { prize, index } = Astro.props;

const isFirst = index === 0;
const rank = index + 1;
const placeLabels = ["First prize", "Second prize", "Third prize"] as const;
const placeLabel = placeLabels[index] ?? `Place ${rank}`;
---

<article
  data-stagger-item
  class:list={[
    "relative rounded-2xl bg-white px-8 pb-10 pt-14 text-center shadow-md transition-shadow duration-300 hover:shadow-lg hover:-translate-y-0.5",
    isFirst
      ? "border-2 border-primary shadow-primary/10 ring-1 ring-primary/10 z-10"
      : "border border-slate-200/90",
  ]}
>
  <span
    class:list={[
      "absolute right-5 top-5 flex h-10 w-10 items-center justify-center rounded-full border-2 font-display text-lg font-bold",
      isFirst
        ? "border-primary bg-primary/10 text-primary"
        : "border-primary/50 bg-white text-primary",
    ]}
    aria-label={`Rank ${rank}`}
  >
    {rank}
  </span>

  <div class="mb-8 flex justify-center">
    <div
      class:list={[
        "inline-flex rounded-full border-2 p-4 text-primary",
        isFirst ? "border-primary bg-primary/5" : "border-primary/35 bg-primary/[0.04]",
      ]}
    >
      <Gift size={40} strokeWidth={1.5} />
    </div>
  </div>

  <p class="font-display text-4xl font-bold tracking-tight text-slate-900 md:text-[2.75rem]">
    {prize.amount}
  </p>
  <p class="mt-2 text-base font-medium text-slate-500">{placeLabel}</p>
  <p class="mx-auto mt-5 max-w-[14rem] text-sm leading-relaxed text-slate-400">{prize.description}</p>
</article>
