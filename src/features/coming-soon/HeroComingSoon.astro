---

<section class="relative min-h-screen flex items-center justify-center overflow-hidden bg-white">
  <!-- Background layers -->
  <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_center,rgba(126,74,158,0.06),transparent_70%)]"></div>
  <div class="absolute inset-0 bg-[radial-gradient(#e5e5e5_1px,transparent_1px)] opacity-40" style="background-size: 40px 40px"></div>

  <!-- Floating orbs -->
  <div class="orb orb-1 absolute -top-32 -left-32 w-[500px] h-[500px] rounded-full bg-primary/[0.06] blur-[120px]"></div>
  <div class="orb orb-2 absolute -bottom-32 -right-32 w-[500px] h-[500px] rounded-full bg-accent/[0.08] blur-[120px]"></div>

  <div class="relative z-10 max-w-2xl mx-auto text-center px-6 py-12">
    <!-- Logo -->
    <div class="logo-wrapper flex justify-center mb-10">
      <img
        src="/lumbinix%20logo.png"
        alt="LumbiniX"
        class="h-14 w-auto md:h-16"
        width="320"
        height="120"
        loading="eager"
      />
    </div>

    <!-- Main Heading -->
    <h1 class="heading mb-6 font-display font-bold tracking-tight leading-none">
      <span class="text-[clamp(3rem,10vw,6rem)]">
        <span class="word inline-block" style="--i:0">Something</span>
        <span class="word inline-block gradient-text ml-[0.2em]" style="--i:1">is</span>
        <span class="word inline-block gradient-text ml-[0.15em]" style="--i:2">coming</span>
      </span>
    </h1>

    <!-- Tagline -->
    <p class="tagline text-lg md:text-xl text-slate-500 max-w-md mx-auto mb-12 font-medium leading-relaxed">
      A new era of innovation is about to begin.
    </p>



    <!-- Social Links -->
    <div class="social-links flex justify-center gap-x-6 mb-14">
      {socialLinks.map((link) => (
        <a
          href={link.href}
          target="_blank"
          aria-label={link.name}
          class="social-link w-12 h-12 bg-slate-100 hover:bg-primary/[0.08] rounded-2xl flex items-center justify-center transition-all duration-300 hover:scale-110 hover:shadow-lg"
        >
          <svg
            class="w-5 h-5 text-slate-500 transition-colors duration-300"
            viewBox="0 0 24 24"
            fill="currentColor"
          >
            <path d={link.path} />
          </svg>
        </a>
      ))}
    </div>

    <!-- Footer -->
    <p class="footer-text text-xs text-slate-400 font-medium tracking-wider uppercase">
      &copy; 2026 LUMBINIX &bull; All Rights Reserved
    </p>
  </div>
</section>

<script>
  (function initParallax() {
    const mq = window.matchMedia('(prefers-reduced-motion: reduce)');
    if (mq.matches) return;

    const orbs = document.querySelectorAll<HTMLElement>('.orb');
    if (!orbs.length) return;

    let ticking = false;
    window.addEventListener('mousemove', (e) => {
      if (!ticking) {
        requestAnimationFrame(() => {
          const x = (e.clientX / window.innerWidth - 0.5) * 2;
          const y = (e.clientY / window.innerHeight - 0.5) * 2;
          orbs.forEach((orb, i) => {
            const speed = 12 + i * 6;
            orb.style.transform = `translate(${x * speed}px, ${y * speed}px)`;
          });
          ticking = false;
        });
        ticking = true;
      }
    }, { passive: true });
  })();
</script>

<style>
  /* ===== Logo entrance ===== */
  .logo-wrapper {
    opacity: 0;
    transform: translateY(16px);
    animation: fadeSlideIn 0.8s cubic-bezier(0.16, 1, 0.3, 1) 0.1s forwards;
  }

  /* ===== Word stagger ===== */
  .word {
    display: inline-block;
    opacity: 0;
    transform: translateY(40px);
    animation: fadeSlideIn 0.7s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    animation-delay: calc(0.4s + var(--i, 0) * 0.18s);
  }

  .gradient-text {
    background: linear-gradient(135deg, #7E4A9E, #9B6BBA, #7E4A9E);
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
  }

  /* ===== Tagline ===== */
  .tagline {
    opacity: 0;
    transform: translateY(24px);
    animation: fadeSlideIn 0.7s cubic-bezier(0.16, 1, 0.3, 1) 0.9s forwards;
  }

  /* ===== Social links ===== */
  .social-links {
    opacity: 0;
    transform: translateY(24px);
    animation: fadeSlideIn 0.7s cubic-bezier(0.16, 1, 0.3, 1) 1.1s forwards;
  }

  .social-link {
    position: relative;
  }
  .social-link::before {
    content: attr(aria-label);
    position: absolute;
    bottom: calc(100% + 8px);
    left: 50%;
    transform: translateX(-50%) scale(0.8);
    background: #1e293b;
    color: white;
    font-size: 0.65rem;
    font-weight: 500;
    padding: 3px 9px;
    border-radius: 5px;
    opacity: 0;
    pointer-events: none;
    transition: all 0.2s ease;
    white-space: nowrap;
  }
  .social-link:hover::before {
    opacity: 1;
    transform: translateX(-50%) scale(1);
  }

  /* ===== Footer ===== */
  .footer-text {
    opacity: 0;
    animation: fadeIn 0.6s ease-out 1.3s forwards;
  }

  /* ===== Keyframes ===== */
  @keyframes fadeSlideIn {
    from { opacity: 0; transform: translateY(24px); }
    to { opacity: 1; transform: translateY(0); }
  }

  @keyframes fadeIn {
    from { opacity: 0; }
    to { opacity: 1; }
  }

  /* ===== Background orbs ===== */
  .orb {
    transition: transform 0.15s ease-out;
    animation: orbFloat 20s ease-in-out infinite;
  }
  .orb-1 { animation-delay: -5s; animation-duration: 22s; }
  .orb-2 { animation-delay: -12s; animation-duration: 18s; }

  @keyframes orbFloat {
    0%, 100% { transform: translateY(0) scale(1); }
    33% { transform: translateY(-20px) scale(1.05); }
    66% { transform: translateY(10px) scale(0.96); }
  }

  /* ===== Reduced motion ===== */
  @media (prefers-reduced-motion: reduce) {
    .logo-wrapper,
    .word,
    .tagline,
    .social-links,
    .footer-text {
      animation: none !important;
      opacity: 1 !important;
      transform: none !important;
    }
    .orb {
      animation: none !important;
      transition: none !important;
    }
    .social-link::before {
      display: none;
    }
  }
</style>
