---

<section class="relative min-h-screen flex flex-col items-center justify-between overflow-hidden bg-white select-none">
  <!-- Background layers -->
  <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_center,rgba(126,74,158,0.06),transparent_70%)]"></div>
  <div class="absolute inset-0 bg-[radial-gradient(#e5e5e5_1px,transparent_1px)] opacity-30 pointer-events-none" style="background-size: 40px 40px"></div>

  <!-- Interactive Particle Canvas -->
  <canvas id="particle-canvas" class="absolute inset-0 pointer-events-none z-0"></canvas>

  <!-- Floating orbs with wrappers for decoupled parallax -->
  <div class="orb-wrapper absolute -top-32 -left-32 w-[500px] h-[500px] pointer-events-none">
    <div class="orb orb-1 w-full h-full rounded-full bg-primary/[0.06] blur-[120px]"></div>
  </div>
  <div class="orb-wrapper absolute -bottom-32 -right-32 w-[500px] h-[500px] pointer-events-none">
    <div class="orb orb-2 w-full h-full rounded-full bg-accent/[0.08] blur-[120px]"></div>
  </div>

  <div class="relative z-10 max-w-2xl mx-auto text-center px-6 py-12 flex-1 flex flex-col items-center justify-center">
    <!-- Logo with Magnetic Hover effect -->
    <div class="logo-wrapper flex justify-center mb-10">
      <div class="magnetic-inner cursor-pointer p-2 flex justify-center items-center">
        <img
          src="/lumbinix%20logo.png"
          alt="LumbiniX"
          class="logo-img h-14 w-auto md:h-16"
          width="320"
          height="120"
          loading="eager"
        />
      </div>
    </div>

    <!-- Main Heading with Split-Text Slide-Up Reveal -->
    <h1 class="heading mb-6 font-display font-bold tracking-tight leading-normal py-2">
      <span class="text-[clamp(3rem,10vw,6rem)] inline-flex flex-wrap justify-center">
        <span class="inline-block overflow-hidden pt-10 -mt-10 pb-6 -mb-6">
          <span class="word inline-block" style="--i:0">Someth<span class="i-dot-wrapper">ı<span class="i-dot" style="--dot-delay: 0.8s">.</span></span>ng</span>
        </span>
        <span class="inline-block overflow-hidden pt-10 -mt-10 pb-6 -mb-6 ml-[0.2em]">
          <span class="word inline-block gradient-text" style="--i:1"><span class="i-dot-wrapper">ı<span class="i-dot" style="--dot-delay: 0.95s">.</span></span>s</span>
        </span>
        <span class="inline-block overflow-hidden pt-10 -mt-10 pb-6 -mb-6 ml-[0.15em]">
          <span class="word inline-block gradient-text" style="--i:2">com<span class="i-dot-wrapper">ı<span class="i-dot" style="--dot-delay: 1.1s">.</span></span>ng</span>
        </span>
      </span>
    </h1>
  </div>

  <!-- Footer section with social links -->
  <div class="relative z-10 flex flex-col items-center gap-6 pb-8">
    <!-- Social Links with Magnetic Hover Inner Wrappers -->
    <div class="social-links flex justify-center gap-x-6">
      {socialLinks.map((link) => (
        <a
          href={link.href}
          target="_blank"
          aria-label={link.name}
          class="social-link w-12 h-12 bg-slate-100 hover:bg-primary/[0.08] rounded-2xl flex items-center justify-center transition-all duration-300 hover:scale-105 hover:shadow-lg group"
        >
          <span class="magnetic-inner flex items-center justify-center w-full h-full">
            <svg
              class="w-5 h-5 text-slate-500 transition-colors duration-300 group-hover:text-primary"
              viewBox="0 0 24 24"
              fill="currentColor"
            >
              <path d={link.path} />
            </svg>
          </span>
        </a>
      ))}
    </div>

    <!-- Footer -->
    <p class="footer-text text-xs text-slate-400 font-medium tracking-wider uppercase">
      &copy; 2026 LUMBINIX &bull; All Rights Reserved
    </p>
  </div>
</section>

<script>
  // Magnetic hover effect configurations
  interface MagneticState {
    el: HTMLElement;
    targetTx: number;
    targetTy: number;
    tx: number;
    ty: number;
  }

  const magneticStates: MagneticState[] = [];
  const magnetics = document.querySelectorAll<HTMLElement>('.magnetic-inner');
  
  magnetics.forEach(el => {
    const state = {
      el,
      targetTx: 0,
      targetTy: 0,
      tx: 0,
      ty: 0
    };
    magneticStates.push(state);

    const parent = el.parentElement;
    if (parent) {
      parent.addEventListener('mousemove', (e: MouseEvent) => {
        const rect = parent.getBoundingClientRect();
        const cx = rect.left + rect.width / 2;
        const cy = rect.top + rect.height / 2;
        const dx = e.clientX - cx;
        const dy = e.clientY - cy;
        // Restrict displacement for subtle premium feel
        const maxDisplacement = 12;
        state.targetTx = Math.min(Math.max(dx * 0.4, -maxDisplacement), maxDisplacement);
        state.targetTy = Math.min(Math.max(dy * 0.4, -maxDisplacement), maxDisplacement);
      });

      parent.addEventListener('mouseleave', () => {
        state.targetTx = 0;
        state.targetTy = 0;
      });
    }
  });

  // Parallax & Canvas state
  let mouseX = -1000;
  let mouseY = -1000;
  let targetMouseX = 0;
  let targetMouseY = 0;
  let currentMouseX = 0;
  let currentMouseY = 0;

  const orbs = document.querySelectorAll<HTMLElement>('.orb-wrapper');
  const canvas = document.getElementById('particle-canvas') as HTMLCanvasElement | null;
  const ctx = canvas ? canvas.getContext('2d') : null;

  let width = 0;
  let height = 0;

  if (canvas && ctx) {
    const container = canvas.parentElement;
    width = canvas.width = container ? container.clientWidth : window.innerWidth;
    height = canvas.height = container ? container.clientHeight : window.innerHeight;
  }

  interface Particle {
    x: number;
    y: number;
    vx: number;
    vy: number;
    radius: number;
    color: string;
  }

  let particles: Particle[] = [];

  function initParticles() {
    if (!canvas) return;
    particles = [];
    // Dynamic particle count based on screen size (increased density)
    const maxParticles = Math.min(200, Math.floor((width * height) / 5000));
    const colors = [
      'rgba(126, 74, 158, 0.15)', // Logo purple
      'rgba(249, 212, 35, 0.12)',  // Logo gold
      'rgba(155, 107, 186, 0.12)'  // Secondary purple
    ];
    for (let i = 0; i < maxParticles; i++) {
      // 12% chance for larger nodes to create a layered depth-of-field look
      const isLarge = Math.random() < 0.12;
      const radius = isLarge ? Math.random() * 2 + 3 : Math.random() * 1.8 + 1;
      
      particles.push({
        x: Math.random() * width,
        y: Math.random() * height,
        vx: (Math.random() - 0.5) * (isLarge ? 0.25 : 0.35), // Larger particles drift slower
        vy: (Math.random() - 0.5) * (isLarge ? 0.25 : 0.35),
        radius,
        color: colors[Math.floor(Math.random() * colors.length)]
      });
    }
  }

  if (canvas) {
    initParticles();
    window.addEventListener('resize', () => {
      const container = canvas.parentElement;
      width = canvas.width = container ? container.clientWidth : window.innerWidth;
      height = canvas.height = container ? container.clientHeight : window.innerHeight;
      initParticles();
    });
  }

  const mq = window.matchMedia('(prefers-reduced-motion: reduce)');
  const isReducedMotion = mq.matches;

  window.addEventListener('mousemove', (e: MouseEvent) => {
    if (isReducedMotion) return;
    mouseX = e.clientX;
    mouseY = e.clientY;

    targetMouseX = (e.clientX / window.innerWidth - 0.5) * 2;
    targetMouseY = (e.clientY / window.innerHeight - 0.5) * 2;
  }, { passive: true });

  // Main animation ticker loop
  function tick() {
    if (isReducedMotion) return;

    // 1. Lerped Parallax Orbs
    if (orbs.length) {
      currentMouseX += (targetMouseX - currentMouseX) * 0.05;
      currentMouseY += (targetMouseY - currentMouseY) * 0.05;
      orbs.forEach((orb, i) => {
        const speed = 15 + i * 8;
        orb.style.transform = `translate(${currentMouseX * speed}px, ${currentMouseY * speed}px)`;
      });
    }

    // 2. Lerped Magnetic Items
    magneticStates.forEach(state => {
      state.tx += (state.targetTx - state.tx) * 0.12;
      state.ty += (state.targetTy - state.ty) * 0.12;
      state.el.style.transform = `translate(${state.tx}px, ${state.ty}px)`;
    });

    // 3. Floating connecting network particles
    if (canvas && ctx) {
      ctx.clearRect(0, 0, width, height);

      // Draw particle links
      for (let i = 0; i < particles.length; i++) {
        for (let j = i + 1; j < particles.length; j++) {
          const dx = particles[i].x - particles[j].x;
          const dy = particles[i].y - particles[j].y;
          const dist = Math.sqrt(dx * dx + dy * dy);
          if (dist < 105) {
            ctx.beginPath();
            ctx.strokeStyle = `rgba(126, 74, 158, ${0.05 * (1 - dist / 105)})`;
            ctx.lineWidth = 0.5;
            ctx.moveTo(particles[i].x, particles[i].y);
            ctx.lineTo(particles[j].x, particles[j].y);
            ctx.stroke();
          }
        }
      }

      // Draw particles
      particles.forEach(p => {
        p.x += p.vx;
        p.y += p.vy;

        // Bounce boundaries
        if (p.x < 0 || p.x > width) p.vx *= -1;
        if (p.y < 0 || p.y > height) p.vy *= -1;

        // Push away from cursor
        if (mouseX !== -1000) {
          const rect = canvas.getBoundingClientRect();
          const localX = mouseX - rect.left;
          const localY = mouseY - rect.top;

          const dx = localX - p.x;
          const dy = localY - p.y;
          const dist = Math.sqrt(dx * dx + dy * dy);
          if (dist < 120) {
            const force = (120 - dist) / 120;
            const angle = Math.atan2(dy, dx);
            p.x -= Math.cos(angle) * force * 1.6;
            p.y -= Math.sin(angle) * force * 1.6;
          }
        }

        ctx.beginPath();
        ctx.arc(p.x, p.y, p.radius, 0, Math.PI * 2);
        ctx.fillStyle = p.color;
        ctx.shadowBlur = 4;
        ctx.shadowColor = p.color;
        ctx.fill();
        ctx.shadowBlur = 0;
      });
    }

    requestAnimationFrame(tick);
  }

  if (!isReducedMotion) {
    requestAnimationFrame(tick);
  }
</script>

<style>
  /* Override dynamic i-dot vertical spacing for this component's heading */
  .heading :global(.i-dot) {
    top: -0.68em;
  }

  /* ===== Logo entrance ===== */
  .logo-wrapper {
    opacity: 0;
    transform: translateY(20px);
    animation: fadeSlideIn 0.8s cubic-bezier(0.16, 1, 0.3, 1) 0.1s forwards;
  }

  .logo-img {
    opacity: 0;
    transform: scale(0.9);
    filter: blur(8px);
    animation: logoReveal 1.2s cubic-bezier(0.16, 1, 0.3, 1) 0.1s forwards;
  }

  /* ===== Word slide-up stagger ===== */
  .word {
    display: inline-block;
    opacity: 0;
    transform: translateY(110%);
    animation: slideUpReveal 1.2s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    animation-delay: calc(0.4s + var(--i, 0) * 0.15s);
  }

  /* ===== Shimmering gradient text ===== */
  .gradient-text {
    background: linear-gradient(90deg, #7E4A9E, #9B6BBA, #F9D423, #9B6BBA, #7E4A9E);
    background-size: 200% auto;
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
  }

  /* Combine slide-up and infinite shimmer for gradient text words */
  .word.gradient-text {
    animation: slideUpReveal 1.2s cubic-bezier(0.16, 1, 0.3, 1) forwards, shimmer 6s linear infinite;
    animation-delay: calc(0.4s + var(--i, 0) * 0.15s), 0s;
  }

  /* ===== Social links stagger ===== */
  .social-links {
    opacity: 0;
    transform: translateY(20px);
    animation: fadeSlideIn 0.8s cubic-bezier(0.16, 1, 0.3, 1) 0.9s forwards;
  }

  .social-link {
    position: relative;
    transition: background-color 0.3s ease, transform 0.3s ease, box-shadow 0.3s ease;
  }

  .social-link::before {
    content: attr(aria-label);
    position: absolute;
    bottom: calc(100% + 8px);
    left: 50%;
    transform: translateX(-50%) scale(0.8);
    background: #1e293b;
    color: white;
    font-size: 0.65rem;
    font-weight: 500;
    padding: 4px 10px;
    border-radius: 6px;
    opacity: 0;
    pointer-events: none;
    transition: all 0.25s cubic-bezier(0.16, 1, 0.3, 1);
    white-space: nowrap;
    box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1), 0 2px 4px -1px rgba(0, 0, 0, 0.06);
  }

  .social-link:hover::before {
    opacity: 1;
    transform: translateX(-50%) scale(1);
  }

  /* ===== Footer ===== */
  .footer-text {
    opacity: 0;
    animation: fadeIn 0.8s ease-out 1.1s forwards;
  }

  /* ===== Keyframes ===== */
  @keyframes fadeSlideIn {
    from { opacity: 0; transform: translateY(20px); }
    to { opacity: 1; transform: translateY(0); }
  }

  @keyframes logoReveal {
    from {
      opacity: 0;
      transform: scale(0.9);
      filter: blur(8px);
    }
    to {
      opacity: 1;
      transform: scale(1);
      filter: blur(0);
    }
  }

  @keyframes slideUpReveal {
    from {
      opacity: 0;
      transform: translateY(110%);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @keyframes shimmer {
    to {
      background-position: 200% center;
    }
  }

  @keyframes fadeIn {
    from { opacity: 0; }
    to { opacity: 1; }
  }

  /* ===== Background orbs (slow pulsing) ===== */
  .orb {
    animation: orbFloat 25s ease-in-out infinite alternate;
  }
  .orb-1 { animation-delay: -5s; }
  .orb-2 { animation-delay: -12s; }

  @keyframes orbFloat {
    0% { transform: scale(1) translate(0, 0); }
    50% { transform: scale(1.1) translate(-20px, 30px); }
    100% { transform: scale(0.95) translate(30px, -20px); }
  }

  /* ===== Reduced motion overrides ===== */
  @media (prefers-reduced-motion: reduce) {
    .logo-wrapper,
    .logo-img,
    .word,
    .social-links,
    .footer-text {
      animation: none !important;
      opacity: 1 !important;
      transform: none !important;
      filter: none !important;
    }
    .orb {
      animation: none !important;
    }
    .social-link::before {
      display: none;
    }
  }
</style>
