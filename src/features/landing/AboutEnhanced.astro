---

<section id="about" class="relative section-padding overflow-hidden bg-white dark:bg-dark-bg transition-colors duration-300">
  <!-- Background decorations -->
  <div class="absolute top-0 right-0 w-1/2 h-full bg-gradient-to-l from-primary/5 to-transparent dark:from-primary/10"></div>
  <div class="absolute top-20 right-20 w-64 h-64 border border-primary/10 rounded-full animate-pulse-slow"></div>

  <div class="container-custom relative z-10">
    <div class="grid lg:grid-cols-2 gap-10 lg:gap-16 items-center">
      <!-- Left content -->
      <div class="animate-slide-right">
        <span class="inline-block px-4 py-2 bg-primary/10 dark:bg-primary/20 text-primary dark:text-primary-light rounded-full text-sm font-semibold mb-6">
          About The Event
        </span>
        <h2 class="text-3xl sm:text-4xl md:text-5xl font-display font-bold text-slate-900 dark:text-white mb-4 sm:mb-6 leading-tight">
          About <span class="text-gradient">LumbiniX</span>
        </h2>
        <p class="text-base sm:text-lg text-slate-600 dark:text-slate-300 leading-relaxed mb-6 sm:mb-8">
          LumbiniX is a national-level hackathon bringing together the brightest minds from across Nepal.
          It's a <strong class="text-slate-800 dark:text-white">48-hour coding marathon</strong> designed
          for students and developers who aspire to build innovative and impactful real-world solutions.
        </p>
        <p class="text-base sm:text-lg text-slate-600 dark:text-slate-300 leading-relaxed mb-6 sm:mb-8">
          LumbiniX is not just a coding competition — it's a platform for <strong class="text-slate-800 dark:text-white">creativity,
          collaboration, and innovation</strong>. Over three days, participants will brainstorm, design, and code non-stop,
          pushing their limits to transform bold ideas into working prototypes.
        </p>

        <!-- CTA -->
        <a
          href="#"
          class="inline-flex items-center gap-2 px-6 py-3 bg-primary hover:bg-primary-dark text-white font-semibold rounded-full transition-all hover:scale-105"
        >
          Learn More
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </a>
      </div>

      <!-- Right - Event Highlights -->
      <div class="animate-slide-left">
        <div class="bg-gradient-to-br from-slate-50 to-slate-100 dark:from-dark-card dark:to-dark-surface rounded-2xl sm:rounded-3xl p-5 sm:p-8 md:p-10 border border-slate-200 dark:border-dark-border">
          <h3 class="text-xl sm:text-2xl font-bold text-slate-900 dark:text-white mb-5 sm:mb-8">
            Event <span class="text-gradient">Highlights</span>
          </h3>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-3 sm:gap-4">
            {highlights.map((item, index) => (
              <div
                class="group flex items-start sm:items-center gap-3 p-3 sm:p-4 bg-white dark:bg-dark-bg rounded-xl border border-slate-200 dark:border-dark-border hover:border-primary/30 hover:shadow-lg hover:shadow-primary/10 transition-all sm:hover:-translate-y-1 animate-fade-up"
                style={`animation-delay: ${index * 100}ms`}
              >
                <div class="flex-shrink-0 w-9 h-9 sm:w-10 sm:h-10 rounded-lg bg-gradient-to-br from-primary/10 to-accent/10 dark:from-primary/20 dark:to-accent/20 flex items-center justify-center text-primary dark:text-primary-light group-hover:scale-110 transition-transform" set:html={item.icon} />
                <span class="text-sm font-medium text-slate-700 dark:text-slate-300 leading-snug">{item.text}</span>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  @keyframes slide-right {
    from { opacity: 0; transform: translateX(-50px); }
    to { opacity: 1; transform: translateX(0); }
  }
  @keyframes slide-left {
    from { opacity: 0; transform: translateX(50px); }
    to { opacity: 1; transform: translateX(0); }
  }
  @keyframes fade-up {
    from { opacity: 0; transform: translateY(20px); }
    to { opacity: 1; transform: translateY(0); }
  }
  @keyframes pulse-slow {
    0%, 100% { transform: scale(1); opacity: 1; }
    50% { transform: scale(1.1); opacity: 0.8; }
  }
  .animate-slide-right { animation: slide-right 0.8s ease-out forwards; }
  .animate-slide-left { animation: slide-left 0.8s ease-out 0.2s forwards; opacity: 0; }
  .animate-fade-up { animation: fade-up 0.5s ease-out forwards; opacity: 0; }
  .animate-pulse-slow { animation: pulse-slow 8s ease-in-out infinite; }
</style>
