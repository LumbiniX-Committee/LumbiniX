---

<section class="relative section-padding overflow-hidden bg-gradient-to-b from-slate-50 to-white dark:from-dark-surface dark:to-dark-bg transition-colors duration-300">
  <!-- Background decoration -->
  <div class="absolute inset-0 opacity-50 pointer-events-none">
    <div class="absolute top-0 left-1/4 w-96 h-96 bg-primary/5 rounded-full blur-[100px]"></div>
    <div class="absolute bottom-0 right-1/4 w-96 h-96 bg-accent/5 rounded-full blur-[100px]"></div>
  </div>

  <div class="container-custom relative z-10">
    <!-- Who Can Participate -->
    <div class="mb-16 sm:mb-24">
      <div class="text-center mb-8 sm:mb-12">
        <span class="inline-block px-4 py-2 bg-primary/10 dark:bg-primary/20 text-primary dark:text-primary-light rounded-full text-sm font-semibold mb-4">
          Eligibility
        </span>
        <h2 class="text-3xl sm:text-4xl md:text-5xl font-display font-bold text-slate-900 dark:text-white mb-4">
          Who Can <span class="text-gradient">Participate?</span>
        </h2>
      </div>

      <div class="max-w-4xl mx-auto">
        <div class="bg-white dark:bg-dark-card rounded-2xl sm:rounded-3xl p-5 sm:p-8 md:p-10 shadow-xl shadow-slate-200/50 dark:shadow-none border border-slate-200 dark:border-dark-border">
          <div class="space-y-3 sm:space-y-4">
            {eligibility.map((item, index) => (
              <div
                class="group flex items-start gap-3 sm:gap-4 p-3 sm:p-4 rounded-xl hover:bg-slate-50 dark:hover:bg-dark-surface transition-all sm:hover:scale-[1.02] animate-fade-up"
                style={`animation-delay: ${index * 100}ms`}
              >
                <div class:list={["flex-shrink-0 w-10 h-10 sm:w-12 sm:h-12 rounded-xl flex items-center justify-center transition-transform group-hover:scale-110", item.color, "bg-current/10"]} set:html={item.icon} />
                <span class="text-sm sm:text-base md:text-lg text-slate-700 dark:text-slate-300 leading-relaxed pt-1 sm:pt-0">{item.text}</span>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>

    <!-- Why Participate -->
    <div>
      <div class="text-center mb-8 sm:mb-12">
        <span class="inline-block px-4 py-2 bg-accent/10 dark:bg-accent/20 text-amber-600 dark:text-accent rounded-full text-sm font-semibold mb-4">
          Benefits
        </span>
        <h2 class="text-3xl sm:text-4xl md:text-5xl font-display font-bold text-slate-900 dark:text-white mb-4">
          Why Join <span class="text-gradient">LumbiniX?</span>
        </h2>
        <p class="text-sm sm:text-base text-slate-600 dark:text-slate-400 max-w-2xl mx-auto px-2">
          More than just a hackathon — 3 days of innovation, learning, and unforgettable experiences
        </p>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 sm:gap-6">
        {benefits.map((benefit, index) => (
          <div
            class="group relative bg-white dark:bg-dark-card rounded-2xl p-5 sm:p-6 md:p-8 shadow-lg shadow-slate-200/50 dark:shadow-none border border-slate-200 dark:border-dark-border overflow-hidden sm:hover:-translate-y-2 transition-all duration-300 animate-fade-up"
            style={`animation-delay: ${index * 100}ms`}
          >
            <!-- Hover gradient -->
            <div class="absolute inset-0 bg-gradient-to-br from-primary/5 to-accent/5 opacity-0 group-hover:opacity-100 transition-opacity"></div>

            <!-- Top accent line -->
            <div class="absolute top-0 left-1/2 -translate-x-1/2 w-0 h-1 bg-gradient-to-r from-primary to-accent group-hover:w-full transition-all duration-500 rounded-b-full"></div>

            <div class="relative z-10">
              <div class="w-14 h-14 rounded-2xl bg-gradient-to-br from-primary/10 to-accent/10 dark:from-primary/20 dark:to-accent/20 flex items-center justify-center mb-4 text-primary dark:text-primary-light group-hover:scale-110 group-hover:rotate-3 transition-all duration-300" set:html={benefit.icon} />
              <h3 class="text-lg sm:text-xl font-bold text-slate-900 dark:text-white mb-2 sm:mb-3">{benefit.title}</h3>
              <p class="text-sm sm:text-base text-slate-600 dark:text-slate-400">{benefit.description}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  @keyframes fade-up {
    from { opacity: 0; transform: translateY(20px); }
    to { opacity: 1; transform: translateY(0); }
  }
  .animate-fade-up { animation: fade-up 0.6s ease-out forwards; opacity: 0; }
</style>
