---
import ScheduleSectionTimeline from "./ScheduleSectionTimeline.astro";
import MainEventSchedule from "./MainEventSchedule.astro";
import Guidelines from "./Guidelines.astro";
import { registrationTimelineMilestones } from "../../data/registrationTimeline";
import { onlineScheduleMilestones } from "../../data/onlineSchedule";
import { eventScheduleDays } from "../../data/eventDays";
import { eventMeta } from "../../data/event";
---

<ScheduleSectionTimeline
  id="registration-timeline"
  eyebrow="Before the venue"
  titleLead="Registration"
  titleGradient="timeline"
  description="Key Bikram Sambat (BS) dates for signing up, closing registration, and hearing whether your team is selected for the main event."
  milestones={registrationTimelineMilestones}
/>

<ScheduleSectionTimeline
  id="online-schedule"
  eyebrow="Remote"
  titleLead="Online"
  titleGradient="schedule"
  description="Virtual touchpoints so teams arrive on-site aligned on rules, themes, and tooling. Times and sessions can be adjusted as the program is finalized."
  milestones={onlineScheduleMilestones}
  variant="alt"
/>

<MainEventSchedule days={eventScheduleDays} />

<Guidelines registrationUrl={eventMeta.registrationUrl} />
