---
import type { ScheduleEntry } from "../../types";
import ScheduleCard from "./ScheduleCard.astro";

interface Props {
  schedule: ScheduleEntry[];
}

const { schedule } = Astro.props;
---

<section id="schedule" class="py-24 bg-bg-alt/50">
  <div class="container-custom">
    <div class="text-center mb-16">
      <h2 class="text-4xl md:text-5xl mb-4">Event <span class="text-gradient">Schedule</span></h2>
      <p class="text-slate-400 max-w-2xl mx-auto">
        Two days packed with innovation, learning, and networking. Don't miss a single beat of the action.
      </p>
    </div>

    <div class="max-w-4xl mx-auto">
      {schedule.map((entry) => (
        <ScheduleCard entry={entry} />
      ))}
    </div>
  </div>
</section>
