---
import type { ScheduleDayBlock } from "../../types";
import FadeIn from "../../components/FadeIn.astro";
import StaggerGroup from "../../components/StaggerGroup.astro";

interface Props {
  days: ScheduleDayBlock[];
}

const { days } = Astro.props;
---

<FadeIn variant="up" threshold={0.05}>
  <section id="main-event-schedule" class="py-24 scroll-mt-24">
    <div class="container-custom">
      <div class="text-center mb-16 max-w-3xl mx-auto">
        <p class="text-primary font-semibold text-sm uppercase tracking-widest mb-3">On-site</p>
        <h2 class="text-4xl md:text-5xl mb-4 font-display font-bold text-slate-900">
          Main event <span class="text-gradient">schedule</span>
        </h2>
        <p class="text-slate-600 leading-relaxed">
          Three days on the ground at LumbiniX — Shrawan 22–24, 2083 BS — kickoff and sprinting, a full
          build day, then submission, demos, and awards.
        </p>
      </div>

      <StaggerGroup baseDelay={0} staggerDelay={200}>
        <div class="max-w-4xl mx-auto space-y-14">
          {days.map((day) => (
            <div class="scroll-mt-24" key={day.bsDay} data-stagger-item>
              <div class="flex flex-col sm:flex-row sm:items-end sm:justify-between gap-2 mb-6 border-b border-slate-200 pb-4">
                <h3 class="text-2xl font-display text-slate-900">{day.dayTitle}</h3>
                <p class="text-sm font-semibold text-primary">{day.bsDay}</p>
              </div>
              <div class="overflow-x-auto rounded-2xl border border-slate-200 bg-white/80 shadow-sm">
                <table class="w-full min-w-[320px] text-left text-sm">
                  <thead>
                    <tr class="border-b border-slate-200 bg-slate-50/80">
                      <th class="py-3 px-4 font-display text-slate-900 w-[40%] sm:w-[36%]">Time</th>
                      <th class="py-3 px-4 font-display text-slate-900">Activity</th>
                    </tr>
                  </thead>
                  <tbody>
                    {day.rows.map((row) => (
                      <tr class="border-b border-slate-100 last:border-0 hover:bg-primary/[0.03] transition-colors schedule-row">
                        <td class="py-3 px-4 text-slate-700 font-medium tabular-nums align-top whitespace-nowrap">
                          {row.time}
                        </td>
                        <td class="py-3 px-4 text-slate-600 align-top">{row.activity}</td>
                      </tr>
                    ))}
                  </tbody>
                </table>
              </div>
            </div>
          ))}
        </div>
      </StaggerGroup>
    </div>
  </section>
</FadeIn>