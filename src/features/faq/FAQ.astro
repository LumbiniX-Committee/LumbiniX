---
import type { FAQ as FAQType } from "../../types";
import FAQAccordion from "./FAQAccordion";

interface Props {
  faqs: FAQType[];
}

const { faqs } = Astro.props;
---

<section id="faq" class="section-padding bg-bg-alt/50 dark:bg-dark-bg transition-colors duration-300">
  <div class="container-custom">
    <div class="mb-10 sm:mb-14 text-center">
      <p class="mb-3 text-sm font-semibold uppercase tracking-[0.4em] text-amber-400/80">FAQs</p>
      <h2 class="text-3xl sm:text-4xl md:text-5xl font-bold text-slate-900 dark:text-white px-2">
        Frequently Asked <span class="text-gradient">Questions</span>
      </h2>
      <p class="mx-auto mt-4 max-w-2xl px-4 text-sm sm:text-base text-slate-500 dark:text-slate-400">
        Choose a topic on the left and open any question on the right.
      </p>
    </div>

    <FAQAccordion client:visible faqs={faqs} />
  </div>
</section>
