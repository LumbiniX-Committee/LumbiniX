---
import type { FAQ as FAQType } from "../../types";
import FAQAccordion from "./FAQAccordion";

interface Props {
  faqs: FAQType[];
}

const { faqs } = Astro.props;
---

<section id="faq" class="section-padding bg-bg-alt/50 dark:bg-dark-bg transition-colors duration-300">
  <div class="container-custom">
    <div class="text-center mb-10 sm:mb-16">
      <h2 class="text-3xl sm:text-4xl md:text-5xl mb-3 sm:mb-4 text-slate-900 dark:text-white px-2">Frequently Asked <span class="text-gradient">Quest<span class="text-gradient">i</span>ons</span></h2>
      <p class="text-sm sm:text-base text-slate-500 dark:text-slate-400 max-w-2xl mx-auto px-4">
        Everything you need to know about the hackathon. Can't find what you're looking for? Reach out to us.
      </p>
    </div>

    <FAQAccordion client:visible faqs={faqs} />
  </div>
</section>
