---
import type { Sponsor } from "../../types";

interface Props {
  sponsors: Sponsor[];
}

const { sponsors } = Astro.props;
const hasSponsors = sponsors.length > 0;
const titleSponsor = sponsors.find((sponsor) => sponsor.role === "Title Sponsor") ?? sponsors.find((sponsor) => Boolean(sponsor.message));
const otherSponsors = sponsors.filter((sponsor) => sponsor.name !== titleSponsor?.name);

type LogoFrame = "circle" | "wide";

const logoFrames: Record<string, { frame: LogoFrame; containerClass?: string; imageClass?: string }> = {
  "Hotel Madani": {
    frame: "wide",
    containerClass: "bg-[#fbf4e2] dark:bg-[#fbf4e2]",
    imageClass: "h-full w-full object-contain",
  },
  "Inovex Media & Tech": {
    frame: "circle",
    containerClass: "bg-black",
    imageClass: "h-full w-full object-cover",
  },
  "Ek Surup": {
    frame: "circle",
    imageClass: "h-full w-full object-cover",
  },
  "Shine Resunga Development Bank Ltd.": {
    frame: "wide",
    containerClass: "bg-white dark:bg-white",
    imageClass: "h-full w-full object-contain",
  },
  "Mawali Ghar": {
    frame: "circle",
    containerClass: "bg-white dark:bg-white",
    imageClass: "h-full w-full object-contain p-2",
  },
  "Paramount Boarding High School": {
    frame: "circle",
    containerClass: "bg-white dark:bg-white",
    imageClass: "h-full w-full object-contain p-1",
  },
  "QFX Cinemas": {
    frame: "wide",
    containerClass: "bg-black",
    imageClass: "h-full w-full object-contain",
  },
  "Butwal Computer Supplier": {
    frame: "wide",
    containerClass: "bg-white dark:bg-white",
    imageClass: "h-full w-full object-contain",
  },
  "The Chocolatier Nepal": {
    frame: "circle",
    imageClass: "h-full w-full object-cover",
  },
};

function getLogoFrame(name: string) {
  return logoFrames[name] ?? { frame: "circle" as const, imageClass: "h-full w-full object-contain p-2" };
}

function getLinkProps(url: string) {
  if (!url || url === "#") return null;
  if (url.startsWith("tel:") || url.startsWith("mailto:")) {
    return { href: url } as const;
  }
  return { href: url, target: "_blank", rel: "noopener noreferrer" } as const;
}

function linkLabel(url: string) {
  if (url.startsWith("tel:")) return "Call Now";
  if (url.startsWith("mailto:")) return "Email Us";
  if (url === "#") return null;
  return "Visit Website";
}
---

<section id="sponsors" class="section-padding relative overflow-hidden bg-slate-100 dark:bg-dark-surface transition-colors duration-300">
  <div class="container-custom relative z-10">
    <div class="text-center mb-10 sm:mb-14">
      <h2 class="text-3xl sm:text-4xl md:text-5xl font-display font-bold text-slate-900 dark:text-white mb-3">
        Our <span class="text-gradient">Sponsors</span>
      </h2>
      <p class="text-sm sm:text-base text-slate-500 dark:text-slate-400 max-w-2xl mx-auto">
        Proud partners powering LumbiniX Hackathon 2026.
      </p>
    </div>

    {hasSponsors ? (
      <div class="space-y-12 sm:space-y-16">
        {titleSponsor && (
          <div class="rounded-3xl bg-white dark:bg-dark-card border border-slate-200/80 dark:border-dark-border shadow-sm px-8 py-12 sm:px-14 sm:py-16 md:px-20 md:py-20">
            <div class="mx-auto flex max-w-xl flex-col items-center text-center">
              <p class="mb-8 sm:mb-10 text-3xl sm:text-4xl md:text-5xl font-display font-bold text-primary dark:text-primary-light">
                Title Sponsor
              </p>

              <div class="mb-6 sm:mb-8 flex h-40 w-40 sm:h-48 sm:w-48 items-center justify-center rounded-full bg-slate-50 dark:bg-dark-surface p-4">
                <img
                  src={titleSponsor.logo}
                  alt={`${titleSponsor.name} logo`}
                  class="max-h-full max-w-full object-contain"
                />
              </div>

              <h3 class="mb-4 text-2xl sm:text-3xl font-bold text-slate-900 dark:text-white">
                {titleSponsor.name}
              </h3>

              {titleSponsor.description && (
                <p class="mb-6 max-w-lg text-sm sm:text-base text-slate-600 dark:text-slate-300 leading-relaxed">
                  {titleSponsor.description}
                </p>
              )}

              {getLinkProps(titleSponsor.url) && (
                <a
                  href={titleSponsor.url}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="inline-block text-base font-semibold text-cyan-600 dark:text-cyan-400 underline underline-offset-4 hover:text-cyan-700 dark:hover:text-cyan-300 transition-colors"
                >
                  Visit Website
                </a>
              )}
            </div>
          </div>
        )}

        {otherSponsors.length > 0 && (
          <div class="rounded-3xl bg-white dark:bg-dark-card border border-slate-200/80 dark:border-dark-border shadow-sm px-6 py-10 sm:px-10 sm:py-12 md:px-14 md:py-14">
            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-x-6 gap-y-10 sm:gap-x-8 sm:gap-y-12 items-stretch">
              {otherSponsors.map((sponsor) => {
                const link = getLinkProps(sponsor.url);
                const label = linkLabel(sponsor.url);
                const logoFrame = getLogoFrame(sponsor.name);
                const isCircle = logoFrame.frame === "circle";

                return (
                  <article class="flex h-full flex-col">
                    <div class="mb-5 flex h-28 items-center justify-start">
                      <div class:list={[
                        "flex items-center justify-center overflow-hidden border border-slate-200 dark:border-dark-border",
                        isCircle
                          ? "h-28 w-28 rounded-full bg-slate-50 dark:bg-dark-surface"
                          : "h-24 w-full max-w-[11.5rem] rounded-2xl px-2",
                        logoFrame.containerClass,
                      ]}>
                        <img
                          src={sponsor.logo}
                          alt={`${sponsor.name} logo`}
                          class={logoFrame.imageClass ?? "h-full w-full object-contain p-2"}
                        />
                      </div>
                    </div>

                    <h3 class="text-lg sm:text-xl font-bold text-slate-900 dark:text-white mb-2 min-h-[1.75rem] sm:min-h-[1.875rem]">
                      {sponsor.name}
                    </h3>

                    <p class="text-xs font-medium text-primary dark:text-primary-light mb-2 min-h-[1rem]">
                      {sponsor.role ?? ""}
                    </p>

                    <p class="text-sm text-slate-600 dark:text-slate-300 leading-relaxed flex-1">
                      {sponsor.description ?? ""}
                    </p>

                    {link && label ? (
                      <a
                        href={link.href}
                        target={"target" in link ? link.target : undefined}
                        rel={"rel" in link ? link.rel : undefined}
                        class="mt-5 inline-block text-sm font-semibold text-cyan-600 dark:text-cyan-400 underline underline-offset-4 hover:text-cyan-700 dark:hover:text-cyan-300 transition-colors"
                      >
                        {label}
                      </a>
                    ) : (
                      <span class="mt-5 inline-block h-5" aria-hidden="true" />
                    )}
                  </article>
                );
              })}
            </div>
          </div>
        )}
      </div>
    ) : (
      <div class="rounded-3xl bg-white dark:bg-dark-card border border-dashed border-slate-300 dark:border-dark-border p-10 sm:p-14 text-center">
        <h3 class="text-2xl font-bold text-slate-900 dark:text-white mb-3">
          Sponsors <span class="text-gradient">Coming Soon</span>
        </h3>
        <p class="text-slate-500 dark:text-slate-400">
          We're finalizing partnerships. Big announcements dropping soon.
        </p>
      </div>
    )}

    <div class="mt-12 sm:mt-16 flex flex-col sm:flex-row sm:items-center sm:justify-between gap-5 rounded-2xl border border-slate-200 dark:border-dark-border bg-white dark:bg-dark-card px-6 py-6 sm:px-8 shadow-sm">
      <div>
        <h3 class="text-lg sm:text-xl font-bold text-slate-900 dark:text-white">
          Interested in sponsoring?
        </h3>
        <p class="text-sm text-slate-500 dark:text-slate-400 mt-1">
          Join us in making LumbiniX 2026 the best hackathon yet.
        </p>
      </div>
      <a
        href="https://www.instagram.com/insta.lumbinix"
        target="_blank"
        rel="noopener noreferrer"
        class="btn-primary text-center text-sm whitespace-nowrap"
      >
        Become a Partner
      </a>
    </div>
  </div>
</section>
