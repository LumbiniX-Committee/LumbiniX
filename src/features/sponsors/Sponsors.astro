---
import type { Sponsor } from "../../types";

interface Props {
  sponsors: Sponsor[];
}

const { sponsors } = Astro.props;
const hasSponsors = sponsors.length > 0;
const featured = sponsors.find((sponsor) => Boolean(sponsor.message));
const otherSponsors = sponsors.filter((sponsor) => sponsor.name !== featured?.name);

const darkLogoSponsors = new Set(["Inovex Media & Tech"]);

function getLinkProps(url: string) {
  if (!url || url === "#") return null;
  if (url.startsWith("tel:") || url.startsWith("mailto:")) {
    return { href: url } as const;
  }
  return { href: url, target: "_blank", rel: "noopener noreferrer" } as const;
}
---

<section id="sponsors" class="section-padding relative overflow-hidden bg-white dark:bg-dark-bg transition-colors duration-300">
  <div class="absolute inset-0 pointer-events-none">
    <div class="absolute top-0 right-0 w-1/2 h-full bg-gradient-to-l from-primary/5 to-transparent dark:from-primary/10"></div>
  </div>

  <div class="container-custom relative z-10">
    <div class="max-w-3xl mb-10 sm:mb-14">
      <p class="text-primary dark:text-primary-light font-semibold text-sm uppercase tracking-widest mb-3">
        Partners
      </p>
      <h2 class="text-3xl sm:text-4xl md:text-5xl font-display font-bold text-slate-900 dark:text-white mb-4">
        Our <span class="text-gradient">Partners</span>
      </h2>
      <p class="text-sm sm:text-base text-slate-600 dark:text-slate-400 leading-relaxed">
        Organizations supporting LumbiniX Hackathon 2026.
      </p>
    </div>

    {hasSponsors ? (
      <div class="space-y-12 sm:space-y-16">
        {featured && (
          <article class="rounded-3xl border border-slate-200 dark:border-dark-border overflow-hidden bg-slate-50 dark:bg-dark-card">
            <div class="grid lg:grid-cols-[280px_1fr]">
              <div class="flex flex-col items-center justify-center gap-4 bg-slate-950 px-8 py-10 lg:py-12">
                <img
                  src={featured.logo}
                  alt={`${featured.name} logo`}
                  class="h-36 w-auto max-w-[200px] object-contain"
                />
                {featured.role && (
                  <span class="inline-flex rounded-full bg-white/10 px-3 py-1 text-[11px] font-semibold uppercase tracking-[0.16em] text-white/80">
                    {featured.role}
                  </span>
                )}
              </div>

              <div class="p-6 sm:p-8 lg:p-10">
                <h3 class="text-2xl sm:text-3xl font-display font-bold text-slate-900 dark:text-white mb-3">
                  {featured.name}
                </h3>
                {featured.description && (
                  <p class="text-sm sm:text-base text-slate-600 dark:text-slate-300 leading-relaxed mb-5">
                    {featured.description}
                  </p>
                )}
                {featured.message && (
                  <blockquote class="rounded-2xl bg-white dark:bg-dark-bg border border-slate-200 dark:border-dark-border p-4 sm:p-5 text-sm sm:text-base text-slate-600 dark:text-slate-300 leading-relaxed">
                    <p class="italic">“{featured.message}”</p>
                    <footer class="mt-3 text-xs sm:text-sm font-semibold not-italic text-primary dark:text-primary-light">
                      — A.Campus Chief, {featured.name}
                    </footer>
                  </blockquote>
                )}
                {featured.url && featured.url !== "#" && (
                  <a
                    href={featured.url}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="inline-flex items-center gap-2 mt-5 text-sm font-semibold text-primary hover:text-primary-dark dark:text-primary-light transition-colors"
                  >
                    Visit {featured.name}
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
                    </svg>
                  </a>
                )}
              </div>
            </div>
          </article>
        )}

        {otherSponsors.length > 0 && (
          <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 sm:gap-5">
              {otherSponsors.map((sponsor) => {
                const link = getLinkProps(sponsor.url);
                const isDarkLogo = darkLogoSponsors.has(sponsor.name);
                const cardClass =
                  "group relative flex flex-col rounded-2xl border border-slate-200 dark:border-dark-border overflow-hidden transition-all duration-300 hover:border-primary/35 hover:shadow-lg hover:shadow-primary/5 bg-white dark:bg-dark-card";

                return link ? (
                  <a
                    href={link.href}
                    target={"target" in link ? link.target : undefined}
                    rel={"rel" in link ? link.rel : undefined}
                    class={cardClass}
                    aria-label={sponsor.name}
                  >
                    <div class:list={["flex h-36 sm:h-40 items-center justify-center px-6", isDarkLogo ? "bg-slate-950" : "bg-slate-50 dark:bg-dark-surface"]}>
                      <img
                        src={sponsor.logo}
                        alt={`${sponsor.name} logo`}
                        class="max-h-24 w-auto max-w-full object-contain transition-transform duration-300 group-hover:scale-[1.03]"
                      />
                    </div>
                    <div class="flex flex-1 flex-col gap-1.5 p-4 sm:p-5 border-t border-slate-100 dark:border-dark-border">
                      <p class="text-sm sm:text-base font-semibold text-slate-900 dark:text-white leading-snug">
                        {sponsor.name}
                      </p>
                      {sponsor.role && (
                        <p class="text-xs font-medium text-primary dark:text-primary-light">
                          {sponsor.role}
                        </p>
                      )}
                      {sponsor.description && (
                        <p class="text-xs text-slate-500 dark:text-slate-400 leading-relaxed mt-1">
                          {sponsor.description}
                        </p>
                      )}
                    </div>
                  </a>
                ) : (
                  <div class={cardClass} aria-label={sponsor.name}>
                    <div class:list={["flex h-36 sm:h-40 items-center justify-center px-6", isDarkLogo ? "bg-slate-950" : "bg-slate-50 dark:bg-dark-surface"]}>
                      <img
                        src={sponsor.logo}
                        alt={`${sponsor.name} logo`}
                        class="max-h-24 w-auto max-w-full object-contain transition-transform duration-300 group-hover:scale-[1.03]"
                      />
                    </div>
                    <div class="flex flex-1 flex-col gap-1.5 p-4 sm:p-5 border-t border-slate-100 dark:border-dark-border">
                      <p class="text-sm sm:text-base font-semibold text-slate-900 dark:text-white leading-snug">
                        {sponsor.name}
                      </p>
                      {sponsor.role && (
                        <p class="text-xs font-medium text-primary dark:text-primary-light">
                          {sponsor.role}
                        </p>
                      )}
                      {sponsor.description && (
                        <p class="text-xs text-slate-500 dark:text-slate-400 leading-relaxed mt-1">
                          {sponsor.description}
                        </p>
                      )}
                    </div>
                  </div>
                );
              })}
            </div>
        )}
      </div>
    ) : (
      <div class="rounded-3xl border border-dashed border-slate-300 dark:border-dark-border p-10 sm:p-14 text-center">
        <h3 class="text-2xl font-bold text-slate-900 dark:text-white mb-3">
          Partners <span class="text-gradient">Coming Soon</span>
        </h3>
        <p class="text-slate-500 dark:text-slate-400">
          We're finalizing partnerships. Big announcements dropping soon.
        </p>
      </div>
    )}

    <div class="mt-12 sm:mt-16 flex flex-col sm:flex-row sm:items-center sm:justify-between gap-5 rounded-2xl border border-slate-200 dark:border-dark-border bg-slate-50 dark:bg-dark-card px-6 py-6 sm:px-8">
      <div>
        <h3 class="text-lg sm:text-xl font-bold text-slate-900 dark:text-white">
          Interested in sponsoring?
        </h3>
        <p class="text-sm text-slate-500 dark:text-slate-400 mt-1">
          Join us in making LumbiniX 2026 the best hackathon yet.
        </p>
      </div>
      <a
        href="https://www.instagram.com/insta.lumbinix"
        target="_blank"
        rel="noopener noreferrer"
        class="btn-primary text-center text-sm whitespace-nowrap"
      >
        Become a Partner
      </a>
    </div>
  </div>
</section>
