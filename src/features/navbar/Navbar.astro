---
import MobileMenu from "./MobileMenu";

const navItems = [
  { label: "Schedule", href: "/schedule" },
  { label: "Prizes", href: "/prizes" },
  { label: "Sponsors", href: "/sponsors" },
  { label: "Team", href: "/team" },
  { label: "FAQ", href: "/faq" },
  { label: "Conduct", href: "/code-of-conduct" },
];
---

<header class="fixed top-0 left-0 right-0 z-50 bg-white/80 backdrop-blur-md border-b border-slate-100">
  <div class="container-custom h-20 flex items-center justify-between">
    <a href="/" class="flex items-center gap-3 group">
      <img src="/lumbinix logo.png" alt="LumbiniX Logo" class="h-12 w-auto group-hover:scale-105 transition-transform duration-300" />
    </a>

    <nav class="hidden md:flex items-center gap-8">
      {navItems.map((item) => (
        <a 
          href={item.href} 
          class="text-sm font-semibold text-slate-600 hover:text-primary transition-colors"
        >
          {item.label}
        </a>
      ))}
      <a href="#" class="btn-primary py-2 px-6 text-sm">Register</a>
    </nav>

    <MobileMenu client:load items={navItems} />
  </div>
</header>
<div class="h-20"></div>
