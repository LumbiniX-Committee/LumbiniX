---
import type { Speaker } from "../../types";
import { Twitter, Linkedin, Github } from "lucide-react";

interface Props {
  speaker: Speaker;
}

const { speaker } = Astro.props;
---

<div class="glass-card overflow-hidden group border-slate-100 shadow-lg shadow-slate-200/50">
  <div class="relative aspect-square overflow-hidden">
    <img 
      src={speaker.image} 
      alt={speaker.name}
      class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-110"
    />
    <div class="absolute inset-0 bg-gradient-to-t from-slate-900/40 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>
    
    <div class="absolute bottom-4 left-4 right-4 flex gap-3 translate-y-8 group-hover:translate-y-0 transition-transform duration-300">
      {speaker.socials?.twitter && (
        <a href={speaker.socials.twitter} class="p-2 bg-white/90 backdrop-blur-md rounded-lg hover:bg-primary hover:text-white text-primary transition-all shadow-md">
          <Twitter size={18} />
        </a>
      )}
      {speaker.socials?.linkedin && (
        <a href={speaker.socials.linkedin} class="p-2 bg-white/90 backdrop-blur-md rounded-lg hover:bg-primary hover:text-white text-primary transition-all shadow-md">
          <Linkedin size={18} />
        </a>
      )}
      {speaker.socials?.github && (
        <a href={speaker.socials.github} class="p-2 bg-white/90 backdrop-blur-md rounded-lg hover:bg-primary hover:text-white text-primary transition-all shadow-md">
          <Github size={18} />
        </a>
      )}
    </div>
  </div>

  <div class="p-6">
    <h3 class="text-xl mb-1 text-slate-900">{speaker.name}</h3>
    <p class="text-primary font-bold text-sm mb-3">{speaker.role} @ {speaker.company}</p>
    <p class="text-slate-600 text-sm leading-relaxed">{speaker.bio}</p>
  </div>
</div>
