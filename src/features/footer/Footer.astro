---
import { eventMeta } from "../../data/event";
---

<footer class="py-16 border-t border-slate-100 bg-slate-50">
  <div class="container-custom">
    <div class="grid grid-cols-1 md:grid-cols-4 gap-12 mb-12">
      <div class="col-span-1 md:col-span-2">
        <a href="/" class="flex items-center gap-3 mb-6">
          <img src="/lumbinix logo.png" alt="LumbiniX Logo" class="h-10 w-auto" />
          <span class="text-xl font-display font-bold text-slate-900">Lumbini<span class="text-primary">X</span></span>
        </a>
        <p class="text-slate-600 max-w-sm mb-6 font-medium">
          {eventMeta.description}
        </p>
        <div class="flex gap-4">
          {['Twitter', 'Discord', 'GitHub', 'LinkedIn'].map((social) => (
            <a href="#" class="w-10 h-10 rounded-full bg-white border border-slate-200 flex items-center justify-center text-slate-400 hover:text-primary hover:border-primary transition-all shadow-sm">
              <span class="sr-only">{social}</span>
              <div class="w-5 h-5 bg-current mask-icon" style={`mask-image: url(/icons/${social.toLowerCase()}.svg)`}></div>
            </a>
          ))}
        </div>
      </div>

      <div>
        <h4 class="font-bold text-slate-900 mb-6">Quick Links</h4>
        <ul class="space-y-4">
          {[
            { label: "Schedule", href: "/schedule" },
            { label: "Speakers", href: "/speakers" },
            { label: "Prizes", href: "/prizes" },
            { label: "Team", href: "/team" },
          ].map((link) => (
            <li>
              <a href={link.href} class="text-slate-600 hover:text-primary font-medium transition-colors">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <div>
        <h4 class="font-bold text-slate-900 mb-6">Resources</h4>
        <ul class="space-y-4">
          {["Code of Conduct", "Privacy Policy", "Sponsorship", "Press Kit"].map((item) => (
            <li>
              <a href="#" class="text-slate-600 hover:text-primary font-medium transition-colors">
                {item}
              </a>
            </li>
          ))}
        </ul>
      </div>
    </div>

    <div class="pt-8 border-t border-slate-200 flex flex-col md:flex-row items-center justify-between gap-6">
      <p class="text-sm text-slate-500 font-medium">
        © 2026 {eventMeta.name}. All rights reserved.
      </p>
      <div class="flex items-center gap-2 text-sm text-slate-400 font-medium">
        <span>Built with</span>
        <a href="https://astro.build" class="text-primary hover:underline">Astro</a>
        <span>&</span>
        <a href="https://react.dev" class="text-primary hover:underline">React</a>
      </div>
    </div>
  </div>
</footer>

<style>
  .mask-icon {
    -webkit-mask-repeat: no-repeat;
    mask-repeat: no-repeat;
    -webkit-mask-position: center;
    mask-position: center;
    -webkit-mask-size: contain;
    mask-size: contain;
  }
</style>
