---
import type { EventMeta } from "../../types";
import CountdownTimer from "./CountdownTimer";
import FadeIn from "../../components/FadeIn.astro";

interface Props {
  event: EventMeta;
}

const { event } = Astro.props;
---

<section class="relative pt-20 pb-32 overflow-hidden">
  <!-- Decorative Elements -->
  <div class="absolute top-0 left-1/2 -translate-x-1/2 w-full max-w-7xl h-full -z-10">
    <div class="absolute top-20 left-10 w-72 h-72 bg-primary/10 rounded-full blur-[120px] parallax-circle" data-parallax-speed="-0.08"></div>
    <div class="absolute bottom-0 right-10 w-72 h-72 bg-accent/20 rounded-full blur-[120px] parallax-circle" data-parallax-speed="0.12"></div>
  </div>

  <div class="container-custom text-center">
    <FadeIn variant="scale" delay={0}>
      <img
        src="/lumbinix logo.png"
        alt="LumbiniX"
        class="mb-10 h-24 w-auto drop-shadow-sm md:h-32 mx-auto"
        width="320"
        height="120"
      />
    </FadeIn>

    <FadeIn variant="up" delay={150}>
      <div class="inline-flex items-center gap-2 px-6 py-2 rounded-full bg-primary/5 border border-primary/10 text-primary font-semibold text-sm mb-8 shadow-sm">
        <span class="relative flex h-2 w-2">
          <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-primary opacity-75"></span>
          <span class="relative inline-flex rounded-full h-2 w-2 bg-primary"></span>
        </span>
        {event.date} • {event.venue}
      </div>
    </FadeIn>

    <FadeIn variant="up" delay={300}>
      <h1 class="text-5xl md:text-7xl lg:text-8xl mb-8 leading-tight">
        Build the Future <br />
        <span class="text-gradient">at {event.name}</span>
      </h1>
    </FadeIn>

    <FadeIn variant="up" delay={450}>
      <p class="text-lg md:text-xl text-slate-600 max-w-3xl mx-auto mb-12 font-medium">
        {event.description}
      </p>
    </FadeIn>

    <FadeIn variant="up" delay={600}>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4 mb-16">
        <a href={event.registrationUrl} class="btn-primary w-full sm:w-auto">Register Now</a>
        <a href="/schedule" class="btn-secondary w-full sm:w-auto">View Schedule</a>
      </div>
    </FadeIn>

    <FadeIn variant="up" delay={800}>
      <CountdownTimer client:load targetDate={event.countdownDate} />
    </FadeIn>
  </div>
</section>

<script>
  const circles = document.querySelectorAll('.parallax-circle');
  if (circles.length > 0 && !window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
    let ticking = false;
    window.addEventListener('scroll', () => {
      if (!ticking) {
        requestAnimationFrame(() => {
          const scrollY = window.scrollY;
          circles.forEach((el) => {
            const speed = parseFloat(el.getAttribute('data-parallax-speed') || '0');
            el.style.transform = `translateY(${scrollY * speed}px)`;
          });
          ticking = false;
        });
        ticking = true;
      }
    }, { passive: true });
  }
</script>
