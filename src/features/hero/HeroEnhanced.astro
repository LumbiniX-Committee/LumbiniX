---
import type { EventMeta } from "../../types";
import CountdownTimer from "./CountdownTimer";

interface Props {
  event: EventMeta;
}

const { event } = Astro.props;
---

<section class="relative min-h-screen flex items-center justify-center overflow-hidden">
  <!-- Video Background -->
  <div class="absolute inset-0 z-0">
    <video
      id="hero-video"
      autoplay
      loop
      playsinline
      class="absolute w-full h-full object-cover"
    >
      <source src="/backgroundvideo.mp4" type="video/mp4" />
    </video>
    <!-- Sound toggle button -->
    <button
      id="sound-toggle"
      class="absolute bottom-24 right-6 z-20 w-12 h-12 rounded-full bg-white/10 backdrop-blur-md border border-white/20 flex items-center justify-center text-white hover:bg-white/20 transition-all duration-300 group"
      aria-label="Toggle sound"
    >
      <!-- Muted icon -->
      <svg id="muted-icon" class="w-6 h-6 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5.586 15H4a1 1 0 01-1-1v-4a1 1 0 011-1h1.586l4.707-4.707C10.923 3.663 12 4.109 12 5v14c0 .891-1.077 1.337-1.707.707L5.586 15z" />
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 14l2-2m0 0l2-2m-2 2l-2-2m2 2l2 2" />
      </svg>
      <!-- Unmuted icon (shown by default) -->
      <svg id="unmuted-icon" class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.536 8.464a5 5 0 010 7.072m2.828-9.9a9 9 0 010 12.728M5.586 15H4a1 1 0 01-1-1v-4a1 1 0 011-1h1.586l4.707-4.707C10.923 3.663 12 4.109 12 5v14c0 .891-1.077 1.337-1.707.707L5.586 15z" />
      </svg>
    </button>
    <script is:inline>
      document.addEventListener('DOMContentLoaded', function() {
        const video = document.getElementById('hero-video');
        const soundToggle = document.getElementById('sound-toggle');
        const mutedIcon = document.getElementById('muted-icon');
        const unmutedIcon = document.getElementById('unmuted-icon');

        if (video) {
          video.currentTime = 6;
          video.volume = 0.3;
          video.muted = false;

          // Try to play with sound
          video.play().catch(function() {
            // Browser blocked autoplay with sound, start muted
            video.muted = true;
            video.play();
            updateIcons(true);
          });

          video.addEventListener('loadedmetadata', function() {
            video.currentTime = 6;
          });

          video.addEventListener('ended', function() {
            video.currentTime = 6;
            video.play();
          });
        }

        function updateIcons(isMuted) {
          if (isMuted) {
            mutedIcon.classList.remove('hidden');
            unmutedIcon.classList.add('hidden');
          } else {
            mutedIcon.classList.add('hidden');
            unmutedIcon.classList.remove('hidden');
          }
        }

        if (soundToggle && video) {
          soundToggle.addEventListener('click', function() {
            video.muted = !video.muted;
            updateIcons(video.muted);
          });
        }
      });
    </script>
    <!-- Dark overlay for better text readability -->
    <div class="absolute inset-0 bg-gradient-to-b from-black/50 via-black/40 to-black/60"></div>
  </div>

  <!-- Fallback gradient background (shows if video doesn't load) -->
  <div class="absolute inset-0 -z-10 bg-gradient-to-b from-slate-900 via-slate-800 to-slate-900"></div>

  <!-- Floating shapes background (hidden) -->
  <!-- <div class="absolute inset-0 overflow-hidden pointer-events-none z-[1]">
    <div class="absolute top-[20%] left-[10%] w-72 h-72 bg-gradient-to-br from-primary/20 to-accent/20 rounded-full blur-3xl animate-float-1"></div>
    <div class="absolute top-[10%] right-[20%] w-56 h-56 bg-gradient-to-br from-accent/20 to-primary/20 rounded-full blur-3xl animate-float-2"></div>
    <div class="absolute bottom-[20%] left-[20%] w-64 h-64 bg-gradient-to-br from-primary/20 to-accent/20 rounded-full blur-3xl animate-float-3"></div>
    <div class="absolute bottom-[30%] right-[10%] w-48 h-48 bg-gradient-to-br from-accent/20 to-primary/20 rounded-full blur-3xl animate-float-1"></div>
  </div> -->

  <!-- Grid pattern (hidden) -->
  <!-- <div class="absolute inset-0 opacity-20 pointer-events-none z-[1]" style="background-image: linear-gradient(rgba(255, 255, 255, 0.1) 1px, transparent 1px), linear-gradient(90deg, rgba(255, 255, 255, 0.1) 1px, transparent 1px); background-size: 50px 50px;"></div> -->

  <!-- Decorative circles (hidden) -->
  <!-- <div class="absolute top-20 left-10 w-72 h-72 border border-white/10 rounded-full animate-spin-slow z-[1]"></div>
  <div class="absolute bottom-20 right-10 w-96 h-96 border border-white/10 rounded-full animate-spin-slower z-[1]"></div> -->

  <!-- Main content -->
  <div class="container-custom relative z-10 text-center py-20">
    <!-- Main Heading -->
    <div class="mb-8 animate-fade-up">
      <h1 class="text-5xl md:text-7xl lg:text-8xl font-display font-bold leading-tight">
        <span class="text-gradient-light relative inline-block">
          LUMBINIX
          <svg class="absolute -bottom-2 left-0 w-full" viewBox="0 0 300 12">
            <path
              d="M0 6 Q75 0 150 6 T300 6"
              fill="none"
              stroke="url(#hero-gradient)"
              stroke-width="3"
              stroke-linecap="round"
              class="animate-draw-line"
            />
            <defs>
              <linearGradient id="hero-gradient" x1="0%" y1="0%" x2="100%" y2="0%">
                <stop offset="0%" stop-color="#7E4A9E" />
                <stop offset="100%" stop-color="#F9D423" />
              </linearGradient>
            </defs>
          </svg>
        </span>
        <br />
        <span class="text-white drop-shadow-lg text-3xl md:text-5xl lg:text-6xl mt-4 block">Where Spirituality Meets Innovation</span>
      </h1>
    </div>

    <!-- Subtitle -->
    <p class="text-lg md:text-xl text-white/80 max-w-3xl mx-auto mb-12 leading-relaxed animate-fade-up-delay drop-shadow-md">
      {event.description}
    </p>

    <!-- CTA Buttons -->
    <div class="flex flex-col sm:flex-row items-center justify-center gap-4 mb-16 animate-fade-up-delay-2">
      <a
        href={event.registrationUrl}
        class="group relative px-8 py-4 bg-primary hover:bg-primary-dark text-white font-bold rounded-full overflow-hidden shadow-xl shadow-primary/40 transition-all duration-300 hover:scale-105"
      >
        <span class="relative z-10 flex items-center gap-2">
          Register Now
          <svg class="w-5 h-5 animate-arrow-bounce" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </span>
        <!-- Shine effect -->
        <div class="absolute inset-0 bg-gradient-to-r from-transparent via-white/20 to-transparent -skew-x-12 animate-shine"></div>
      </a>

      <a
        href="/schedule"
        class="px-8 py-4 bg-white/10 backdrop-blur-sm border-2 border-white/30 text-white font-bold rounded-full hover:bg-white/20 hover:border-white/50 transition-all duration-300 hover:scale-105"
      >
        View Schedule
      </a>
    </div>

    <!-- Countdown -->
    <div class="animate-fade-up-delay-3">
      <p class="text-sm font-semibold text-white/70 uppercase tracking-widest mb-6">
        Event Starts In
      </p>
      <CountdownTimer client:load targetDate={event.countdownDate} />
    </div>

    <!-- Scroll indicator -->
    <div class="absolute bottom-8 left-1/2 -translate-x-1/2 animate-bounce-slow">
      <div class="w-6 h-10 border-2 border-white/40 rounded-full flex justify-center pt-2">
        <div class="w-1.5 h-3 bg-white rounded-full animate-scroll-indicator"></div>
      </div>
    </div>
  </div>
</section>

<style>
  .text-gradient-light {
    background: linear-gradient(135deg, #F9D423 0%, #FF6B6B 50%, #F9D423 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    filter: drop-shadow(0 2px 4px rgba(0,0,0,0.3));
  }

  @keyframes float-1 {
    0%, 100% { transform: translate(0, 0); }
    50% { transform: translate(30px, -30px); }
  }
  @keyframes float-2 {
    0%, 100% { transform: translate(0, 0); }
    50% { transform: translate(-20px, 20px); }
  }
  @keyframes float-3 {
    0%, 100% { transform: translate(0, 0); }
    50% { transform: translate(20px, 30px); }
  }
  @keyframes spin-slow {
    from { transform: rotate(0deg); }
    to { transform: rotate(360deg); }
  }
  @keyframes spin-slower {
    from { transform: rotate(0deg); }
    to { transform: rotate(-360deg); }
  }
  @keyframes fade-down {
    from { opacity: 0; transform: translateY(-20px); }
    to { opacity: 1; transform: translateY(0); }
  }
  @keyframes fade-up {
    from { opacity: 0; transform: translateY(30px); }
    to { opacity: 1; transform: translateY(0); }
  }
  @keyframes draw-line {
    from { stroke-dashoffset: 300; }
    to { stroke-dashoffset: 0; }
  }
  @keyframes arrow-bounce {
    0%, 100% { transform: translateX(0); }
    50% { transform: translateX(5px); }
  }
  @keyframes shine {
    from { transform: translateX(-200%) skewX(-12deg); }
    to { transform: translateX(200%) skewX(-12deg); }
  }
  @keyframes bounce-slow {
    0%, 100% { transform: translateX(-50%) translateY(0); }
    50% { transform: translateX(-50%) translateY(10px); }
  }
  @keyframes scroll-indicator {
    0%, 100% { transform: translateY(0); opacity: 1; }
    50% { transform: translateY(12px); opacity: 0; }
  }

  .animate-float-1 { animation: float-1 20s ease-in-out infinite; }
  .animate-float-2 { animation: float-2 25s ease-in-out infinite; }
  .animate-float-3 { animation: float-3 18s ease-in-out infinite; }
  .animate-spin-slow { animation: spin-slow 50s linear infinite; }
  .animate-spin-slower { animation: spin-slower 60s linear infinite; }
  .animate-fade-down { animation: fade-down 0.6s ease-out forwards; }
  .animate-fade-up { animation: fade-up 0.8s ease-out forwards; }
  .animate-fade-up-delay { animation: fade-up 0.6s ease-out 0.2s forwards; opacity: 0; }
  .animate-fade-up-delay-2 { animation: fade-up 0.6s ease-out 0.4s forwards; opacity: 0; }
  .animate-fade-up-delay-3 { animation: fade-up 0.6s ease-out 0.6s forwards; opacity: 0; }
  .animate-draw-line {
    stroke-dasharray: 300;
    stroke-dashoffset: 300;
    animation: draw-line 1s ease-out 1s forwards;
  }
  .animate-arrow-bounce { animation: arrow-bounce 1.5s ease-in-out infinite; }
  .animate-shine { animation: shine 2s ease-in-out infinite; animation-delay: 1s; }
  .animate-bounce-slow { animation: bounce-slow 2s ease-in-out infinite; }
  .animate-scroll-indicator { animation: scroll-indicator 2s ease-in-out infinite; }
</style>
