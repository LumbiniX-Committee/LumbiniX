---
import BaseLayout from "../layouts/BaseLayout.astro";
import Navbar from "../features/navbar/Navbar.astro";
import Schedule from "../features/schedule/Schedule.astro";
import Footer from "../features/footer/Footer.astro";
import { eventMeta } from "../data/event";
---

<BaseLayout
  title={`Schedule | ${eventMeta.name}`}
  description="LumbiniX registration timeline, online program, main on-site schedule (Shrawan 22–24), and team selection guidelines."
>
  <Navbar />
  <main class="pt-12">
    <Schedule />
  </main>

  <Footer />
</BaseLayout>
