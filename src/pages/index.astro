---
import BaseLayout from "../layouts/BaseLayout.astro";
import HeroComingSoon from "../features/coming-soon/HeroComingSoon.astro";
import Navbar from "../features/navbar/Navbar.astro";
import Footer from "../features/footer/Footer.astro";
import HeroEnhanced from "../features/hero/HeroEnhanced.astro";
import StatsSection from "../features/landing/StatsSection";
import Prizes from "../features/prizes/Prizes.astro";
import Team from "../features/team/Team.astro";
import Sponsors from "../features/sponsors/Sponsors.astro";
import FAQ from "../features/faq/FAQ.astro";
import { eventMeta } from "../data/event";
import { organizationSchema, eventSchema } from "../data/schema";
import { eventLeads, organizingCommittee, volunteers } from "../data/teamMembers";
import { sponsors } from "../data/sponsors";
import { faqs } from "../data/faqs";

// Control flag: set to true to show Coming Soon landing page, false to show full index experience
const SHOW_COMING_SOON = false;
const schemas = [organizationSchema, eventSchema];
---

{SHOW_COMING_SOON ? (
  <BaseLayout
    pageKey="coming-soon"
    schema={schemas}
  >
    <HeroComingSoon />
  </BaseLayout>
) : (
  <BaseLayout
    pageKey="home"
    schema={schemas}
  >
    <Navbar />
    <main>
      <HeroEnhanced event={eventMeta} />
      <StatsSection client:visible />
      <Prizes />
      <Team eventLeads={eventLeads} committee={organizingCommittee} volunteers={volunteers} />
      <Sponsors sponsors={sponsors} />
      <FAQ faqs={faqs} />
    </main>
    <Footer />
  </BaseLayout>
)}
