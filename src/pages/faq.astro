---
import BaseLayout from "../layouts/BaseLayout.astro";
import Navbar from "../features/navbar/Navbar.astro";
import FAQ from "../features/faq/FAQ.astro";
import Footer from "../features/footer/Footer.astro";
import { faqs } from "../data/faqs";
import { eventMeta } from "../data/event";
---

<BaseLayout 
  title={`FAQ | ${eventMeta.name}`} 
  description="Find answers to common questions about participation, teams, and logistics for LumbiniX 2026."
>
  <Navbar />
  <main class="pt-12">
    <FAQ faqs={faqs} />
  </main>
  
  <Footer />
</BaseLayout>
