---
import BaseLayout from "../layouts/BaseLayout.astro";
import Navbar from "../features/navbar/Navbar.astro";
import Team from "../features/team/Team.astro";
import Footer from "../features/footer/Footer.astro";
import { eventLeads, organizingCommittee } from "../data/teamMembers";
import { eventMeta } from "../data/event";
---

<BaseLayout
  title={`Organizing Team | ${eventMeta.name}`}
  description="Meet the Lumbini City College student organizing committee behind LumbiniX, featuring event leads, roles, and team."
>
  <Navbar />
  <main class="pt-12">
    <Team eventLeads={eventLeads} committee={organizingCommittee} />
  </main>

  <Footer />
</BaseLayout>
