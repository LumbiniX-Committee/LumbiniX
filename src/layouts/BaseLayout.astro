---
import "../styles/global.css";
import SEO from "../components/SEO.astro";
import WelcomeModal from "../components/WelcomeModal";
import { pageSEO } from "../data/seo";
import type { PageSEO } from "../types/seo";

interface Props {
  title?: string;
  description?: string;
  pageKey?: string;
  schema?: Array<Record<string, any>>;
}

const { title, description, pageKey, schema = [] } = Astro.props;

// Resolve SEO object
let seo: PageSEO;
if (pageKey && pageSEO[pageKey]) {
  seo = { ...pageSEO[pageKey] };
  if (title) seo.title = title;
  if (description) seo.description = description;
} else {
  // Build fallback page-specific SEO
  seo = {
    title: title || "LumbiniX Hackathon 2026 | Nepal's Premier Tech Event",
    description: description || "Join LumbiniX Hackathon 2026 in Lumbini, Nepal. A premier technology event bringing together students, developers, and innovators.",
    keywords: ['LumbiniX Hackathon', 'Nepal tech hackathon', 'student hackathon Nepal'],
    canonical: Astro.url.pathname,
    ogType: 'website'
  };
}
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />

    <SEO seo={seo} schema={schema} />

    <slot name="head" />

    <!-- Prevent flash on page load -->
    <script is:inline>
      const theme = localStorage.getItem('theme');
      const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
      if (theme === 'dark' || (!theme && prefersDark)) {
        document.documentElement.classList.add('dark');
      }
    </script>
  </head>
  <body class="bg-bg text-slate-800 dark:bg-dark-bg dark:text-slate-200 transition-colors duration-300">
    <!-- Subtle Background Glow - Light Mode -->
    <div class="fixed inset-0 -z-10 bg-[radial-gradient(circle_at_top_right,_var(--tw-gradient-stops))] from-primary/5 via-white to-white dark:from-primary/10 dark:via-dark-bg dark:to-dark-bg transition-all duration-300"></div>
    <div class="fixed inset-0 -z-10 bg-[radial-gradient(circle_at_bottom_left,_var(--tw-gradient-stops))] from-accent/10 via-transparent to-transparent dark:from-accent/5 transition-all duration-300"></div>

    <!-- Dark mode animated gradient mesh -->
    <div class="fixed inset-0 -z-10 opacity-0 dark:opacity-100 transition-opacity duration-500">
      <div class="absolute top-0 left-1/4 w-96 h-96 bg-primary/20 rounded-full blur-[150px] animate-float"></div>
      <div class="absolute bottom-1/4 right-1/4 w-80 h-80 bg-accent/15 rounded-full blur-[120px] animate-float-slow"></div>
    </div>

    <slot />

    <WelcomeModal client:load />

    <script>
      function isInsideGradientText(node: Node): boolean {
        let parent = node.parentNode;
        while (parent && parent !== document.body) {
          if (parent instanceof HTMLElement && (
            parent.classList.contains('text-gradient') || 
            parent.classList.contains('gradient-text') ||
            parent.classList.contains('bg-clip-text')
          )) {
            return true;
          }
          parent = parent.parentNode;
        }
        return false;
      }

      function initIDots() {
        const sections = document.querySelectorAll('section');
        
        // Setup intersection observer to trigger section animations on scroll
        const observer = new IntersectionObserver((entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add('in-view');
              // Unobserve once triggered to only animate once
              observer.unobserve(entry.target);
            }
          });
        }, {
          threshold: 0.1, // Trigger when 10% of the section is visible
          rootMargin: '0px 0px -50px 0px' // Slightly offset bottom margin for better visibility flow
        });

        sections.forEach((section) => {
          // Find the main heading in this section to apply the bouncing dot
          const heading = section.querySelector('h1, h2, .animate-i-dots');
          if (heading && !(heading as HTMLElement).dataset.iDotsProcessed) {
            (heading as HTMLElement).dataset.iDotsProcessed = 'true';
            
            const walker = document.createTreeWalker(heading, NodeFilter.SHOW_TEXT);
            const textNodes: Text[] = [];
            let node;
            while (node = walker.nextNode()) {
              textNodes.push(node as Text);
            }
            
            let hasAnimatedOne = false;
            
            for (const textNode of textNodes) {
              const text = textNode.nodeValue || '';
              
              // Only animate the very first lowercase 'i' we find in the heading text nodes
              if (!hasAnimatedOne && text.includes('i') && !text.includes('ı')) {
                const fragment = document.createDocumentFragment();
                const firstIndex = text.indexOf('i');
                
                if (firstIndex > 0) {
                  fragment.appendChild(document.createTextNode(text.substring(0, firstIndex)));
                }
                
                const wrapper = document.createElement('span');
                wrapper.className = 'i-dot-wrapper';
                wrapper.textContent = 'ı';
                
                const dot = document.createElement('span');
                dot.className = 'i-dot';
                dot.textContent = '.';
                dot.style.setProperty('--dot-delay', '0.6s');
                
                wrapper.appendChild(dot);
                fragment.appendChild(wrapper);
                
                if (firstIndex + 1 < text.length) {
                  fragment.appendChild(document.createTextNode(text.substring(firstIndex + 1)));
                }
                
                if (textNode.parentNode) {
                  textNode.parentNode.replaceChild(fragment, textNode);
                }
                
                hasAnimatedOne = true;
                break;
              }
            }
          }

          observer.observe(section);
        });
      }

      // Execute on page load
      initIDots();
    </script>
  </body>
</html>
